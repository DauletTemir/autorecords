PORT=3001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key
# Must exactly match the deployed frontend URL (Cloudflare Pages URL or
# custom domain), including the https:// scheme and with no trailing slash —
# used for the CORS allow-origin check, so a mismatch here breaks every
# frontend request.
FRONTEND_ORIGIN=http://localhost:5173

# Optional: one-way backup of a single org's data into Google Sheets.
# Leave unset to disable the feature entirely. See docs/BACKUP.md.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
BACKUP_SPREADSHEET_ID=
BACKUP_ORG_ID=
